// ═══════════════════════════════════════════════════════════════════
// S7-1200 SCL Reference Code for Web Motion Control Dashboard
// Controller: Siemens SIMATIC S7-1200 (CPU 1214C or similar)
// Servo Drive: Yaskawa SGD7S-120A10A
// Motor: Yaskawa SGM7G-09AFA6C (900W)
//
// IMPORTANT: This is reference code. Adapt to your TIA Portal project.
// ═══════════════════════════════════════════════════════════════════

// ─── SECTION 1: Data Block for Modbus Communication ──────────────
// Create a DB (e.g., DB10 "ModbusData") with NON-OPTIMIZED access.
// In TIA Portal: Right-click DB → Properties → Uncheck "Optimized block access"
//
// DB10 Structure (maps to Modbus Holding Registers):
//   Offset 200 (HR 100): StatusWord        : Word    // Bit-packed axis status
//   Offset 202 (HR 101): PositionHI        : Word    // Actual position high word
//   Offset 204 (HR 102): PositionLO        : Word    // Actual position low word  
//   Offset 206 (HR 103): ActualVelocity    : Int     // mm/s signed
//   Offset 208 (HR 104): TorqueX10         : Word    // Torque % × 10
//   Offset 210 (HR 105): AlarmCode         : Word    // Active alarm (0=none)
//   Offset 212 (HR 106): DriveTempX10      : Word    // Drive temp °C × 10
//   Offset 214 (HR 107): BusVoltage        : Word    // DC bus voltage (V)
//   Offset 400 (HR 200): CommandWord       : Word    // Bit-packed commands
//   Offset 402 (HR 201): TargetPosHI       : Word    // Target position high
//   Offset 404 (HR 202): TargetPosLO       : Word    // Target position low
//   Offset 406 (HR 203): TargetVelocity    : Word    // Move velocity mm/s


// ─── SECTION 2: MB_SERVER Setup (Call in OB1 or a cyclic OB) ─────
// This allows the Node.js backend to read/write the ModbusData DB.
//
// "MB_SERVER_DB"(
//     Disconnect := FALSE,
//     NDR => #newDataReceived,
//     DR => #dataRead,
//     Error => #mbError,
//     Status => #mbStatus,
//     MB_HOLD_REG := "ModbusData"       // Your non-optimized DB
// );


// ─── SECTION 3: Command Word Bit Decoding ────────────────────────
// Read the command word written by the web dashboard
//
// #cmdWord := "ModbusData".CommandWord;   // HR 200 = DBW400
//
// #cmd_ServoOn     := #cmdWord.%X0;       // Bit 0: Servo ON request
// #cmd_ServoOff    := #cmdWord.%X1;       // Bit 1: Servo OFF request
// #cmd_StartHome   := #cmdWord.%X2;       // Bit 2: Start homing
// #cmd_AbsMove     := #cmdWord.%X3;       // Bit 3: Execute absolute move
// #cmd_JogFwd      := #cmdWord.%X4;       // Bit 4: Jog forward
// #cmd_JogRev      := #cmdWord.%X5;       // Bit 5: Jog reverse
// #cmd_Stop        := #cmdWord.%X6;       // Bit 6: Immediate stop
// #cmd_ResetAlarm  := #cmdWord.%X7;       // Bit 7: Reset alarms


// ─── SECTION 4: MC_Power — Enable/Disable Servo ─────────────────
//
// "MC_Power_DB"(
//     Axis := "Axis_1",
//     Enable := #cmd_ServoOn AND NOT #cmd_ServoOff,
//     StartMode := 1,                    // 1 = direct enable
//     StopMode := 0,                     // 0 = emergency stop on disable
//     Status => #axis_Enabled,
//     Busy => #power_Busy,
//     Error => #power_Error
// );


// ─── SECTION 5: MC_Jog — Jog Forward / Backward ─────────────────
// THIS IS YOUR FIRST TEST! Start with this block.
// Press and hold Jog FWD or Jog REV on the web dashboard.
//
// "MC_Jog_DB"(
//     Axis := "Axis_1",
//     JogForward := #cmd_JogFwd,         // Bit 4 from web dashboard
//     JogBackward := #cmd_JogRev,        // Bit 5 from web dashboard
//     Velocity := 10.0,                  // Start SLOW! 10 mm/s for first test
//     Acceleration := 50.0,              // mm/s²
//     Deceleration := 50.0,              // mm/s²
//     Busy => #jog_Busy,
//     Error => #jog_Error
// );
//
// SAFETY TIP: Start with Velocity := 10.0 for your first test.
// Once confirmed working, gradually increase to 50.0 mm/s.


