# 🚀 PRODUCTION ENVIRONMENT VARIABLES
# Copy this file to .env and update with your actual values

# ===========================================
# 🔐 SECURITY CONFIGURATION
# ===========================================
# Generate a strong secret key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-use-strong-random-key

# Flask Environment
FLASK_ENV=production
FLASK_DEBUG=False

# ===========================================
# 🗄️ DATABASE CONFIGURATION
# ===========================================
# SQLite (for small apps)
# DATABASE_URL=sqlite:///invoice_generator.db

# PostgreSQL (Recommended for production)
# DATABASE_URL=postgresql://username:password@host:port/database_name

# MySQL (Alternative)
# DATABASE_URL=mysql://username:password@host:port/database_name

# ===========================================
# 📧 EMAIL CONFIGURATION
# ===========================================
# Gmail SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# Alternative: SendGrid
# MAIL_SERVER=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your-sendgrid-api-key

# ===========================================
# 🏢 COMPANY INFORMATION
# ===========================================
COMPANY_NAME=Your Company Name
COMPANY_EMAIL=company@example.com

# ===========================================
# 📁 FILE UPLOAD SETTINGS
# ===========================================
MAX_FILE_SIZE=16777216  # 16MB in bytes
UPLOAD_FOLDER=static/uploads

# ===========================================
# 🔒 SECURITY SETTINGS
# ===========================================
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600

# ===========================================
# ⚙️ APPLICATION SETTINGS
# ===========================================
INVOICE_PREFIX=INV
DEFAULT_TAX_RATE=18.0
DEFAULT_DUE_DAYS=30
INVOICES_PER_PAGE=20
CUSTOMERS_PER_PAGE=20

# ===========================================
# 🌐 HOSTING PLATFORM SPECIFIC
# ===========================================

# For Railway
# PORT=8000

# For Render
# PORT=10000

# For Heroku
# PORT=5000

# ===========================================
# 📊 MONITORING & LOGGING (Optional)
# ===========================================
# Sentry DSN for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Log level
LOG_LEVEL=INFO

# ===========================================
# 🚀 PERFORMANCE SETTINGS
# ===========================================
# Gunicorn workers (adjust based on your server)
WORKERS=2

# Database connection pool size
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ===========================================
# 🔧 ADVANCED SETTINGS
# ===========================================
# Session configuration
PERMANENT_SESSION_LIFETIME=86400  # 24 hours

# Rate limiting (if using Flask-Limiter)
RATELIMIT_STORAGE_URL=memory://

# Cache configuration (if using Redis)
# REDIS_URL=redis://localhost:6379/0

# ===========================================
# 📝 NOTES
# ===========================================
# 1. Never commit this file with real credentials
# 2. Use environment variables in production
# 3. Rotate SECRET_KEY regularly
# 4. Use strong, unique passwords
# 5. Enable HTTPS in production
# 6. Set up regular database backups
